# Optional AI provider for execution, planning, summaries, and semantic retrieval.
# Use ollama for a no-key local model; openai, gemini, or anthropic for hosted providers;
# openai-compatible for custom gateways; or leave blank for fallback mode.
OPENAGENTGRAPH_AI_PROVIDER=ollama
OPENAGENTGRAPH_AI_MODEL=llama3.2
OPENAGENTGRAPH_AI_BASE_URL=
OPENAGENTGRAPH_AI_API_KEY=
OPENAGENTGRAPH_AI_EMBEDDING_MODEL=
OPENAGENTGRAPH_OLLAMA_BASE_URL=http://localhost:11434/v1

# Provider-specific key fallbacks when OPENAGENTGRAPH_AI_API_KEY is blank.
OPENAI_API_KEY=
GEMINI_API_KEY=
ANTHROPIC_API_KEY=

# Optional runtime mode: development, test, or production.
NODE_ENV=development

# Optional backend port.
PORT=3001

# Optional SQLite data directory.
DATA_DIR=./data

# Optional public backend URL used for diagnostics and same-origin deployment assumptions.
OPENAGENTGRAPH_PUBLIC_BASE_URL=https://api.example.com

# Optional comma-separated frontend origins allowed by backend CORS.
# Leave blank for same-origin deployments, or set explicit origins for split frontend/backend hosting.
OPENAGENTGRAPH_ALLOWED_ORIGINS=https://app.example.com,https://staging.example.com

# Optional workspace root for execution features.
OPENAGENTGRAPH_WORKSPACE_ROOT=./workspace

# Optional structured logging level: debug, info, warn, or error.
OPENAGENTGRAPH_LOG_LEVEL=info

# Auth mode:
# - dev_header for local actor header shims
# - jwt for verified bearer tokens in staging/production
OPENAGENTGRAPH_AUTH_MODE=dev_header

# Development-only auth shortcut. Unsafe for production unless you have
# explicitly chosen OPENAGENTGRAPH_AUTH_MODE=dev_header for a tightly controlled environment.
OPENAGENTGRAPH_ALLOW_ACTOR_HEADERS=true

# Keep false in normal deployments. Only set true if you explicitly accept
# production actor-header auth risk for a tightly controlled environment.
OPENAGENTGRAPH_ALLOW_UNSAFE_DEV_AUTH_IN_PRODUCTION=false

# Optional actor configuration JSON. Keep this as safe sample data only.
OPENAGENTGRAPH_ACTORS=[{"actorId":"operator","displayName":"Operator","role":"operator"},{"actorId":"reviewer","displayName":"Reviewer","role":"reviewer"}]

# Required when OPENAGENTGRAPH_AUTH_MODE=jwt. Use a long random shared secret for HS256 verification.
OPENAGENTGRAPH_JWT_SECRET=replace-with-a-long-random-secret

# Optional role mapping fallbacks when a valid token has no recognized OpenAgentGraph role claim.
OPENAGENTGRAPH_AUTH_OPERATOR_EMAILS=operator@example.com
OPENAGENTGRAPH_AUTH_REVIEWER_EMAILS=reviewer@example.com
OPENAGENTGRAPH_AUTH_ADMIN_EMAILS=admin@example.com
OPENAGENTGRAPH_AUTH_OPERATOR_DOMAINS=ops.example.com
OPENAGENTGRAPH_AUTH_REVIEWER_DOMAINS=review.example.com
OPENAGENTGRAPH_AUTH_ADMIN_DOMAINS=admin.example.com

# Optional OpenTelemetry/OpenInference export. Leave disabled unless an OTLP collector is configured.
OPENAGENTGRAPH_OTEL_ENABLED=false
OPENAGENTGRAPH_OTEL_EXPORTER_OTLP_ENDPOINT=https://otel-collector.example.com/v1/traces
OPENAGENTGRAPH_OTEL_EXPORTER_OTLP_HEADERS=x-api-key=replace-with-collector-key

# Optional tail-based evidence compaction for healthy node completions.
OPENAGENTGRAPH_SAMPLING_ENABLED=true
OPENAGENTGRAPH_SAMPLING_HEALTHY_DURATION_MS=800

# Optional scan emergency breakers for larger repositories.
OPENAGENTGRAPH_SCAN_MAX_FILES=20000
OPENAGENTGRAPH_SCAN_MAX_TOTAL_BYTES=200000000
OPENAGENTGRAPH_SCAN_MAX_FILE_BYTES=5000000
OPENAGENTGRAPH_SCAN_MAX_DEPTH=40
OPENAGENTGRAPH_SCAN_MAX_DURATION_MS=180000

# Optional semantic code intelligence breakers. Legacy OPENAGENTGRAPH_SEMANTIC_ANALYSIS_*
# aliases for files, total bytes, and duration still work.
OPENAGENTGRAPH_SEMANTIC_MAX_FILES=5000
OPENAGENTGRAPH_SEMANTIC_MAX_TOTAL_BYTES=50000000
OPENAGENTGRAPH_SEMANTIC_MAX_FILE_BYTES=5000000
OPENAGENTGRAPH_SEMANTIC_MAX_DEPTH=40
OPENAGENTGRAPH_SEMANTIC_MAX_DURATION_MS=30000
OPENAGENTGRAPH_SEMANTIC_ANALYSIS_MAX_FILES=5000
OPENAGENTGRAPH_SEMANTIC_ANALYSIS_MAX_TOTAL_BYTES=50000000
OPENAGENTGRAPH_SEMANTIC_ANALYSIS_MAX_DURATION_MS=30000
